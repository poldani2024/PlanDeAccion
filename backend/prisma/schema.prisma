generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String
  avatar        String?
  timezone      String   @default("America/Argentina/Buenos_Aires")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  objectives    Objective[]
  achievements  UserAchievement[]
  settings      UserSettings?

  @@map("users")
}

model UserSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  theme                 String   @default("light")
  language              String   @default("es")
  notifications         Boolean  @default(true)
  weeklyReviewDay       Int      @default(0)
  reminderTime          String   @default("20:00")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Objective {
  id                  String          @id @default(cuid())
  userId              String
  title               String
  positiveIntention   String
  values              String[]
  evidence            String
  currentState        String
  availableResources  String[]
  neededResources     String[]
  obstacles           String[]
  positiveConsequences String[]
  negativeConsequences String[]
  status              ObjectiveStatus @default(ACTIVE)
  targetDate          DateTime?
  completedAt         DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  actions      Action[]
  weeklyReviews WeeklyReview[]
  dailyLogs    DailyLog[]

  @@map("objectives")
}

enum ObjectiveStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ARCHIVED
}

model Action {
  id            String       @id @default(cuid())
  objectiveId   String
  title         String
  description   String?
  estimatedTime Int?
  difficulty    Difficulty   @default(MEDIUM)
  energyLevel   EnergyLevel  @default(MEDIUM)
  targetDate    DateTime?
  priority      Priority     @default(MEDIUM)
  category      String?
  status        ActionStatus @default(PENDING)
  notes         String?
  order         Int          @default(0)
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  objective   Objective    @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  logEntries  ActionLog[]

  @@map("actions")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  VERY_HARD
}

enum EnergyLevel {
  LOW
  MEDIUM
  HIGH
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
  SKIPPED
}

model DailyLog {
  id               String   @id @default(cuid())
  objectiveId      String
  date             DateTime @db.Date
  emotionBefore    Int      // 1-10
  emotionAfter     Int?     // 1-10
  motivationLevel  Int      // 1-10
  energyLevel      Int      // 1-10
  timeInvested     Int?     // minutes
  comments         String?
  learnings        String?
  blockerType      BlockerType?
  blockerNote      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  objective   Objective   @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  actionLogs  ActionLog[]

  @@unique([objectiveId, date])
  @@map("daily_logs")
}

model ActionLog {
  id          String   @id @default(cuid())
  dailyLogId  String
  actionId    String
  completed   Boolean  @default(false)
  timeSpent   Int?     // minutes
  note        String?
  createdAt   DateTime @default(now())

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  action   Action   @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@map("action_logs")
}

enum BlockerType {
  PROCRASTINATION
  FORGOT
  NO_TIME
  LOST_MOTIVATION
  FEAR
  DISTRACTED
  DIDNT_KNOW_HOW
  OTHER
}

model WeeklyReview {
  id              String   @id @default(cuid())
  objectiveId     String
  weekNumber      Int
  year            Int
  whatWorked      String?
  whatDidntWork   String?
  learnings       String?
  whatToChange    String?
  nextWeekPlan    String?
  overallRating   Int?     // 1-10
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  objective Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@unique([objectiveId, weekNumber, year])
  @@map("weekly_reviews")
}

model NlpSession {
  id           String      @id @default(cuid())
  userId       String
  objectiveId  String?
  technique    NlpTechnique
  notes        String?
  completed    Boolean     @default(false)
  createdAt    DateTime    @default(now())

  @@map("nlp_sessions")
}

enum NlpTechnique {
  REFRAMING
  ANCHORING
  SWITCH_PATTERN
  SUBMODALITIES
  PARTS_INTEGRATION
  LOGICAL_LEVELS
  TIMELINE
}

model Achievement {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String
  icon        String
  category    String
  createdAt   DateTime @default(now())

  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}
